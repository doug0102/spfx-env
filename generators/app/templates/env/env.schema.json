{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SPFx Environment Variables",
  "description": "Schema for env-inject environment files. All fields required unless marked optional.",
  "type": "object",
  "required": [
    "solutionName",
    "solutionId",
    "solutionPackageZipPath",
    "webApiPermissions",
    "libraryId",
    "manifests"
  ],
  "properties": {
    "$schema":      { "type": "string" },
    "_environment": { "type": "string", "description": "Informational label (dev/uat/prod)" },
    "_description": { "type": "string" },

    "solutionName": {
      "type": "string",
      "description": "Maps to package-solution.json → solution.name"
    },
    "solutionId": {
      "type": "string",
      "format": "uuid",
      "description": "Maps to package-solution.json → solution.id"
    },
    "solutionPackageZipPath": {
      "type": "string",
      "description": "Maps to package-solution.json → paths.zippedPackage. Must end in .sppkg"
    },

    "webApiPermissions": {
      "type": "array",
      "description": "Maps to package-solution.json → solution.webApiPermissionRequests[*].resource",
      "items": {
        "type": "object",
        "required": ["webApiPermName"],
        "properties": {
          "webApiPermName": {
            "type": "string",
            "description": "The resource value for this permission request entry"
          }
        }
      }
    },

    "libraryId": {
      "type": "string",
      "format": "uuid",
      "description": "Maps to .yo-rc.json → @microsoft/generator-sharepoint.libraryId"
    },

    "manifests": {
      "type": "array",
      "description": "One entry per *-manifest.schema.json file in the project",
      "items": {
        "type": "object",
        "required": ["manifestId", "webGroupId", "webTitle"],
        "properties": {
          "manifestId": {
            "type": "string",
            "format": "uuid",
            "description": "Maps to manifest → id"
          },
          "webGroupId": {
            "type": "string",
            "format": "uuid",
            "description": "Maps to manifest → preconfiguredEntries[*].groupId"
          },
          "webTitle": {
            "type": "string",
            "description": "Maps to manifest → preconfiguredEntries[*].title"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
